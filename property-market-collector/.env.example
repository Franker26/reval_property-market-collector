APP_ENV=development

DATABASE_URL=postgresql+asyncpg://reval:reval@localhost:5432/reval_mi
SYNC_DATABASE_URL=postgresql://reval:reval@localhost:5432/reval_mi

REDIS_URL=redis://localhost:6379/0

SERVICE_TOKEN=

COLLECTOR_TIMEZONE=America/Argentina/Buenos_Aires
COLLECTOR_ALLOWED_START_HOUR=9
COLLECTOR_ALLOWED_END_HOUR=22

ZONAPROP_BASE_URL=https://www.zonaprop.com.ar
ZONAPROP_API_POSTINGS_URL=https://www.zonaprop.com.ar/rplis-api/postings
ZONAPROP_ENABLE_SESSION_WARMUP=true
