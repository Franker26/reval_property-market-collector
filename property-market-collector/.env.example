APP_ENV=development

DATABASE_URL=postgresql+asyncpg://reval:reval@localhost:5432/reval_mi
SYNC_DATABASE_URL=postgresql://reval:reval@localhost:5432/reval_mi

SERVICE_TOKEN=
REVAL_MI_API_KEY=

COLLECTOR_TIMEZONE=America/Argentina/Buenos_Aires

ZONAPROP_BASE_URL=https://www.zonaprop.com.ar
ZONAPROP_API_POSTINGS_URL=https://www.zonaprop.com.ar/rplis-api/postings
ZONAPROP_ENABLE_SESSION_WARMUP=true
ZONAPROP_WARMUP_URL=https://www.zonaprop.com.ar/inmuebles-venta.html
ZONAPROP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Rate limiter para url_discovery (si aparecen HTTP 429, subir MIN a 2, MAX a 6, bajar BURST a 15)
ZONAPROP_URL_DISCOVERY_MIN_DELAY=1.5
ZONAPROP_URL_DISCOVERY_MAX_DELAY=4
ZONAPROP_URL_DISCOVERY_BURST_LIMIT=20

WRITE_DATABASE=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alertas: umbrales configurables
ALERT_ERROR_RATE_THRESHOLD=10
ALERT_CONSECUTIVE_4XX_THRESHOLD=3

# url_discovery: la ventana queda abierta hasta su cierre y re-consulta la cola
# cada N segundos cuando está idle (para consumir lo que encole refresh_monitor).
URL_DISCOVERY_IDLE_POLL_SECONDS=60

# Refresh monitor (Etapa B): reencola segmentos completos por churn observado
# (señal principal) + volatilidad de total_count + volumen (secundarias).
# Los gaps son máximos de frescura por negocio: cold = máximo tolerable, no abandono.
# Segmentos sin historial de churn => tier 'unknown' (exploración, gap propio).
REFRESH_MONITOR_ENABLED=true
REFRESH_GAP_HOURS_HOT=24
REFRESH_GAP_HOURS_WARM=72
REFRESH_GAP_HOURS_COLD=168
REFRESH_GAP_HOURS_UNKNOWN=72
REFRESH_WEIGHT_CHURN=0.50
REFRESH_WEIGHT_VOLATILITY=0.25
REFRESH_WEIGHT_VOLUME=0.25
# churn_norm = min(churn_ewma / REFRESH_CHURN_CAP, 1.0) — 5% de churn diario = calor máximo
REFRESH_CHURN_CAP=0.05
REFRESH_CHURN_EWMA_ALPHA=0.50
# Muestras de churn necesarias para salir de 'unknown'. Subir a 2 si el score resulta ruidoso.
REFRESH_MIN_CHURN_SAMPLES=1
# Presupuesto antibot por ciclo: páginas estimadas (principal) + segmentos (tope secundario)
REFRESH_MAX_PAGES_PER_CYCLE=1500
REFRESH_POSTINGS_PER_PAGE=20
REFRESH_MAX_SEGMENTS_PER_CYCLE=50
REFRESH_HOT_SCORE_THRESHOLD=0.70
REFRESH_WARM_SCORE_THRESHOLD=0.35
REFRESH_HIGH_VOLUME_THRESHOLD=1500
REFRESH_VOLATILITY_LOOKBACK_SNAPSHOTS=5
REFRESH_VOLATILITY_CAP=0.10
REFRESH_MIN_AGE_HOURS=12
# Herencia en splits: los hijos reciben churn_ewma del padre como prior débil.
# Regla: REFRESH_INHERITED_CHURN_SAMPLES_CAP = REFRESH_MIN_CHURN_SAMPLES - 1
# (el prior nunca habilita score v2 por sí solo; solo inicializa el EWMA).
REFRESH_INHERIT_CHURN_ON_SPLIT=true
REFRESH_INHERITED_CHURN_SAMPLES_CAP=0

# Full scan de salida en vivo (baseline + compare). Doble gate: requiere
# FULL_SCAN_ENABLED=true Y batch_id explícito (CLI --batch-id o FULL_SCAN_BATCH_ID).
FULL_SCAN_ENABLED=false
FULL_SCAN_MAX_PAGES_PER_CYCLE=1500
FULL_SCAN_POSTINGS_PER_PAGE=20
FULL_SCAN_BATCH_ID=